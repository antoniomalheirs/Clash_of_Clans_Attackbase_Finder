<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp"
        tools:context=".MainActivity">

        <!-- Título -->
        <TextView
            android:id="@+id/textview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="Open Clans"
            android:textColor="#E0E0E0"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Status OCR -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="24dp"
            android:background="#22FFFFFF"
            android:gravity="center"
            android:minHeight="44dp"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp"
            android:text="Pronto para iniciar"
            android:textColor="#B0B0B0"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textview" />

        <!-- ═══ Seção: Limiares de Recursos ═══ -->

        <TextView
            android:id="@+id/labelSection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="28dp"
            android:layout_marginTop="24dp"
            android:text="Limiares Mínimos"
            android:textColor="#80CBC4"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/statusText" />

        <!-- Limiar Ouro/Elixir (Millions) -->
        <TextView
            android:id="@+id/labelThresholdMillion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="28dp"
            android:layout_marginTop="12dp"
            android:text="Ouro/Elixir mínimo"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/labelSection" />

        <EditText
            android:id="@+id/inputThresholdMillion"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="28dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="28dp"
            android:background="#33FFFFFF"
            android:hint="1000000"
            android:inputType="number"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="1000000"
            android:textColor="#E0E0E0"
            android:textColorHint="#555555"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/labelThresholdMillion"
            tools:ignore="HardcodedText,Autofill,LabelFor" />

        <!-- Limiar Dark Elixir (Ten Thousands) -->
        <TextView
            android:id="@+id/labelThresholdTenK"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="28dp"
            android:layout_marginTop="12dp"
            android:text="Dark Elixir mínimo"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/inputThresholdMillion" />

        <EditText
            android:id="@+id/inputThresholdTenK"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="28dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="28dp"
            android:background="#33FFFFFF"
            android:hint="5000"
            android:inputType="number"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="5000"
            android:textColor="#E0E0E0"
            android:textColorHint="#555555"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/labelThresholdTenK"
            tools:ignore="HardcodedText,Autofill,LabelFor" />

        <!-- ═══ Seção: Contagens Mínimas ═══ -->

        <TextView
            android:id="@+id/labelSectionCounts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="28dp"
            android:layout_marginTop="24dp"
            android:text="Contagens Mínimas"
            android:textColor="#80CBC4"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/inputThresholdTenK" />

        <!-- Mín. recursos acima do limiar "million" -->
        <TextView
            android:id="@+id/labelMinMillionCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="28dp"
            android:layout_marginTop="12dp"
            android:text="Recursos acima do limiar Ouro/Elixir"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/labelSectionCounts" />

        <EditText
            android:id="@+id/inputMinMillionCount"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="28dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="28dp"
            android:background="#33FFFFFF"
            android:hint="2"
            android:inputType="number"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="2"
            android:textColor="#E0E0E0"
            android:textColorHint="#555555"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/labelMinMillionCount"
            tools:ignore="HardcodedText,Autofill,LabelFor" />

        <!-- Mín. recursos acima do limiar "ten thousand" -->
        <TextView
            android:id="@+id/labelMinTenKCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="28dp"
            android:layout_marginTop="12dp"
            android:text="Recursos acima do limiar Dark Elixir"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/inputMinMillionCount" />

        <EditText
            android:id="@+id/inputMinTenKCount"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="28dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="28dp"
            android:background="#33FFFFFF"
            android:hint="1"
            android:inputType="number"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="1"
            android:textColor="#E0E0E0"
            android:textColorHint="#555555"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/labelMinTenKCount"
            tools:ignore="HardcodedText,Autofill,LabelFor" />

        <!-- ═══ Botão Start/Stop ═══ -->
        <Button
            android:id="@+id/button"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="#4CAF50"
            android:text="Start"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/inputMinTenKCount"
            tools:ignore="HardcodedText" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>